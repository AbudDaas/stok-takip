{
  "id": "./index.html",
  "name": "Bakkal Stok Takip",
  "short_name": "Stok Takip",
  "description": "Ürün stok takibi, giriş-çıkış ve QR kod ile sayım",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#F2F5FA",
  "theme_color": "#1F3864",
  "orientation": "portrait",
  "display_override": [
    "window-controls-overlay",
    "tabbed",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "lang": "tr",
  "dir": "ltr",
  "categories": [
    "business",
    "productivity",
    "shopping"
  ],
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "id": "com.abuddaas.stoktakip"
    }
  ],
  "icons": [
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "screenshots/screenshot-kasa.png",
      "sizes": "1280x862",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Kasa - QR okutarak satış"
    },
    {
      "src": "screenshots/screenshot-urunler.png",
      "sizes": "1280x884",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Ürün ekleme ekranı"
    },
    {
      "src": "screenshots/screenshot-narrow.png",
      "sizes": "720x1037",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Kasa ekranı (mobil görünüm)"
    }
  ],
  "shortcuts": [
    {
      "name": "Kasa",
      "short_name": "Kasa",
      "description": "Hızlıca kasa ekranını aç",
      "url": "./index.html?tab=tab-kasa",
      "icons": [
        {
          "src": "icons/icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Ürün Ekle",
      "short_name": "Ürün Ekle",
      "description": "Hızlıca yeni ürün ekleme ekranını aç",
      "url": "./index.html?tab=tab-products",
      "icons": [
        {
          "src": "icons/icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "QR Tara",
      "short_name": "QR Tara",
      "description": "Hızlıca QR/barkod tarama ekranını aç",
      "url": "./index.html?tab=tab-scan",
      "icons": [
        {
          "src": "icons/icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "share_target": {
    "action": "./index.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "photos",
          "accept": [
            "image/*"
          ]
        }
      ]
    }
  },
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "edge_side_panel": {
    "preferred_width": 480
  },
  "tab_strip": {
    "home_tab": {
      "scope_patterns": [
        {
          "pathname": "/stok-takip/*"
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "./index.html?fileimport=1",
      "accept": {
        "text/csv": [
          ".csv"
        ]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+bakkal",
      "url": "./index.html?weblink=%s"
    }
  ],
  "widgets": [
    {
      "name": "Stok Özeti",
      "description": "Toplam ürün ve sipariş durumunu gösterir",
      "tag": "stok-widget",
      "template": "stok-widget-template",
      "ms_ac_template": "widgets/stok-widget-template.json",
      "data": "widgets/stok-widget-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "screenshots/screenshot-narrow.png",
          "sizes": "720x1037",
          "label": "Stok özeti widget'ı"
        }
      ],
      "icons": [
        {
          "src": "icons/icon-192.png",
          "sizes": "192x192"
        }
      ],
      "auth": false,
      "update": 86400
    }
  ],
  "note_taking": {
    "new_note_url": "./index.html?newnote=1"
  }
}
