    "productivity",
    "shopping"
  ],
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "id": "com.abuddaas.stoktakip"
    }
  ],
  "icons": [
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "screenshots/screenshot-kasa.png",
      "sizes": "1280x862",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Kasa - QR okutarak satış"
    },
    {
      "src": "screenshots/screenshot-urunler.png",
      "sizes": "1280x884",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Ürün ekleme ekranı"
    },
    {
      "src": "screenshots/screenshot-narrow.png",
      "sizes": "720x1037",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Kasa ekranı (mobil görünüm)"
    }
  ],
  "shortcuts": [
    {
      "name": "Kasa",
      "short_name": "Kasa",
